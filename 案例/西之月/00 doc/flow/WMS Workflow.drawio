        <mxCell id="JQ42pu3G-M6yKnbrvMz_-1" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;入库相关流程&lt;/h1&gt;&lt;p&gt;在西之月，仓库的入库收货要区分开，分为海外仓、皓物仓、工厂仓、物料仓四种场景，不同的场景对入库的要求是不同的；&lt;/p&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="760" height="120" as="geometry" />
        </mxCell>
        <mxCell id="DBpdtO5fo5uarN-ISOIn-1" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;原料仓&lt;/h1&gt;&lt;p&gt;Lorem ipsum dolor sit amet, consectetur adipisicing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="760" height="120" as="geometry" />
        </mxCell>
