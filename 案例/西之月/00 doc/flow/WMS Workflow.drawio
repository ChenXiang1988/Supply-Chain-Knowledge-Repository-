  <diagram id="F11sUsXultUsxdh7yUCW" name="入库相关">
    <mxGraphModel dx="1181" dy="778" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
